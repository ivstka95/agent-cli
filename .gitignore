# Ignore Gradle project-specific cache directory
.gradle

# Ignore Gradle build output directory
build

# Kotlin compiler session cache
.kotlin

# macOS Finder metadata
.DS_Store

# Agent memory store at the repo root (runtime state; never committed).
# Root-anchored so it does NOT match the source package app/.../org/example/memory/.
/memory/

# Day-18 background-digest state (last-seen SHAs + counters; runtime state, never committed).
# Separate from memory/ — different data. Root-anchored, like /memory/.
/digest/

# Day-19 MCP server file-output dir (save_to_file writes here; runtime artifacts, never committed).
# Root-anchored: this is where `./gradlew :mcp:run` (working dir = mcp/) resolves the default "out".
/mcp/out/

# Day-20 filesystem-server sandbox (the third-party server reads/writes here; runtime, never committed).
# Root-anchored: matches the default MCP_FS_DIR resolved against the repo root in app/Main.kt.
/agent-fs/

# Day-21 RAG vector index output (JSON indexes written by :rag:run; runtime artifacts, never committed).
# Root-anchored: matches the default RAG_INDEX_DIR resolved against the repo root (:rag:run workingDir).
/rag-index/
